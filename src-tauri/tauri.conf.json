{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VANTA",
  "version": "1.0.0",
  "identifier": "com.vanta.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VANTA",
        "width": 1200,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "center": true,
        "backgroundColor": "#0b0b0d"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
